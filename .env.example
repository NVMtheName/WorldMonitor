# World Monitor - API Keys
# All keys are optional. Some panels work without any keys.
# Keys are entered via the Settings UI and stored in browser localStorage.

# NewsAPI - https://newsapi.org/register
NEWSAPI_KEY=

# NewsData.io - https://newsdata.io/register
NEWSDATA_KEY=

# OpenWeatherMap - https://openweathermap.org/api
OPENWEATHERMAP_KEY=

# Finnhub - https://finnhub.io/register
FINNHUB_KEY=

# ExchangeRate API - https://www.exchangerate-api.com/
EXCHANGERATE_KEY=

# Polygon.io - https://polygon.io/dashboard/signup
POLYGONIO_KEY=
